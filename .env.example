# Copy to .env and adjust: `cp .env.example .env`
#
# In Docker Compose, DATABASE_URL and REDIS_URL are set by docker-compose.yml.
# You can still override them here if needed.
#
# Required for production
DJANGO_SETTINGS_MODULE=microscopis.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Plain HTTP (typical for local Docker on port 8000). For public HTTPS behind Nginx/Caddy,
# set DJANGO_SECURE_SSL_REDIRECT=true and SESSION_/CSRF_COOKIE_SECURE=true (the defaults).
DJANGO_SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0

# PostgreSQL (used by the `db` service and the default DATABASE_URL in compose)
POSTGRES_USER=microscopis
POSTGRES_PASSWORD=microscopis
POSTGRES_DB=microscopis

# Gunicorn (optional)
# GUNICORN_TIMEOUT=120
#
# Default: sync, 3 workers. For a snappier local Docker (especially macOS), try threaded I/O:
#   GUNICORN_WORKER_CLASS=gthread
#   GUNICORN_WORKERS=1
#   GUNICORN_THREADS=6
# Production on Linux often keeps sync and raises GUNICORN_WORKERS instead.

# Set to 1 to skip automatic `seed_microscopis` on first start (empty database only; see DEPLOY.md)
# SKIP_AUTO_SEED=0

# Seeded /media/ heroes are stored as same-origin paths in the DB (e.g. /media/synthetic/...).
# PUBLIC_BASE_URL is optional (emails, tools); not required for hero <img> URLs in templates.
PUBLIC_BASE_URL=http://127.0.0.1:8000
# MEDIA_URL=/media/
# MEDIA_ROOT=/app/media
# SERVE_MEDIA_THROUGH_DJANGO=1
#
# Optional local Stable Diffusion (start stack with: docker compose --profile with-sd up -d --build)
# SD_ENABLED=0
# SD_URL=http://imagegen:8080
# SD_MODEL=runwayml/stable-diffusion-v1-5
# SD_INFERENCE_STEPS=18
# SD_TIMEOUT_SECONDS=300

# Pre-rendered hero PNGs in git: assets/seed_heroes/{verso|khula|chronicle|z}/ (see that README)
# auto = use file if present, else SD/Pillow | offline = bundled files only (missing → error) | generate = always SD/Pillow
# SYNTHETIC_MODE=auto
# SEED_HEROES_DIR=/app/assets/seed_heroes
# SEED_HERO_OFFLINE_CREDIT=Pre-rendered seed image (bundled in repository).
# Article-grounded image prompts: sanitized title/excerpt in SD/Pillow (set 0 to use generic category-only prompts)
# SEED_IMAGE_GROUNDED=1
# SEED_IMAGE_MAX_PROMPT_WORDS=40
# SD_DEFAULT_NEGATIVE_PROMPT=text, watermark, signature, logo, deformed, blurry, low quality, ugly, bad anatomy

# Web corpus for seeds (trafilatura + RSS): run `python manage.py ingest_web_corpus` then `seed_microscopis`.
# Needs 1300+ rows in IngestedArticle (pool `omni`) to fill all 13 site partitions; see DEPLOY.md.
# INGEST_OMNI_POOL=omni
# USE_SYNTHETIC_SEED_FALLBACK=1
# INGEST_USER_AGENT=microscopis-web-ingest/1.0
# INGEST_IMAGE_ALLOW_ALL=1
# INGEST_IMAGE_MAX_BYTES=8000000
# INGEST_HTTP_TIMEOUT=40
#
# ingest_sourced_hero + seed rows with sourced_image_url (see docs/AGENT_SOURCING_HEROES.md)
# Default allowlist in code if unset: upload.wikimedia.org,commons.wikimedia.org,images.unsplash.com
# SEED_SOURCED_IMAGE_ALLOW_HOSTS=upload.wikimedia.org,commons.wikimedia.org,images.unsplash.com
# SEED_SOURCED_IMAGE_MAX_BYTES=5000000
# SEED_SOURCED_IMAGE_TIMEOUT=60

# Optional: Celery (defaults match REDIS_URL in compose)
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=
